#!/bin/bash
# betterGeoPort .app launcher.
#
# iOS 17+ location tunnels need root. We elevate via the standard macOS admin
# prompt and run the bundled server in the FOREGROUND of that prompt — a
# backgrounded (nohup &) process gets killed when the privileged helper exits,
# so foreground is what keeps it alive. This launcher blocks while the server
# runs, which keeps the app "open" in the Dock; quitting the app stops it.
# The browser is opened (as the normal user) once the server is reachable.

BUNDLE="$(cd "$(dirname "$0")/.." && pwd)"
BIN="$BUNDLE/Resources/GeoPort/GeoPort"
PORT=54321
URL="http://localhost:$PORT/"

up() { /usr/bin/curl -s -o /dev/null -m 1 "$URL"; }

# Already running? Just focus the UI.
if up; then
  /usr/bin/open "$URL"
  exit 0
fi

# Open the browser once the server answers (first boot unpacks deps, ~20s).
(
  for _ in $(seq 1 150); do
    if up; then /usr/bin/open "$URL"; exit 0; fi
    sleep 1
  done
  /usr/bin/open "$URL"   # open anyway after the wait so the user can refresh
) &

# Run the server as root in the foreground (one password prompt). Blocks here
# for the life of the server. Output goes to /tmp/geoport.log for debugging.
exec /usr/bin/osascript <<APPLESCRIPT
do shell script "'${BIN}' --no-browser --port ${PORT} > /tmp/geoport.log 2>&1" with administrator privileges
APPLESCRIPT
