#!/bin/bash
# GeoPort .app launcher.
# iOS 17+ location tunnels need root, so elevate via the standard macOS admin
# prompt, start the bundled server, then open the browser as the normal user.

BUNDLE="$(cd "$(dirname "$0")/.." && pwd)"
BIN="$BUNDLE/Resources/GeoPort/GeoPort"
PORT=54321
URL="http://localhost:$PORT/"

already_up() { /usr/bin/curl -s -o /dev/null -m 1 "$URL"; }

if ! already_up; then
  # Start the server as root (one password prompt), detached so it keeps running.
  /usr/bin/osascript -e "do shell script \"nohup '$BIN' --no-browser --port $PORT > /tmp/geoport.log 2>&1 &\" with administrator privileges" || exit 1
fi

# Wait for it to come up, then open the UI.
for i in $(seq 1 45); do
  if already_up; then /usr/bin/open "$URL"; exit 0; fi
  sleep 1
done

/usr/bin/open "$URL"
